# NSW Tenancy Law RAG - Environment Variables
# Copy this file to .env and fill in your values

# CodingPlan API (LLM)
# Get your API key from: https://codingplan.cn
CODINGPLAN_API_KEY=your_api_key_here
CODINGPLAN_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
CODINGPLAN_MODEL=astron-code-latest

# Optional: HuggingFace Mirror (for users in China)
HF_ENDPOINT=https://hf-mirror.com
